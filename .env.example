# Required — get one at https://openrouter.ai/keys (free credits on signup)
OPENROUTER_API_KEY=sk-or-v1-...

# Database
DATABASE_URL=postgresql+asyncpg://ats_user:ats_password@postgres:5432/ats_parser

# Redis
REDIS_URL=redis://redis:6379

# Optional: AWS Textract OCR (falls back to Tesseract if absent)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# LLM Settings — OpenRouter model ID (vendor/model[:variant])
# OpenRouter rotates free models frequently — verify slug at https://openrouter.ai/models
# Paid but cheap (stable, recommended default):
#   google/gemini-2.5-flash       ($0.30/M in, $2.50/M out) ~$0.001/resume
#   google/gemini-2.5-flash-lite  (cheaper, less capable)
#   google/gemini-2.5-pro         ($1.25/M in, $10/M out)   highest quality
# Free (if currently listed on OpenRouter — check before using):
#   google/gemma-3-12b-it:free
#   google/gemma-3-27b-it:free
LLM_MODEL=google/gemini-2.5-flash
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=8192
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=90

# Parser Settings
MAX_FILE_SIZE_MB=10
MIN_TEXT_LENGTH=100
MIN_CONFIDENCE_FOR_AUTO_ACCEPT=0.70

EMBEDDING_MODEL=all-MiniLM-L6-v2
